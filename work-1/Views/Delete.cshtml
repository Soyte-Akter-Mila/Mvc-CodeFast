@model Mila_Fashion.Models.ViewModels.CustomerVM
@{
    ViewBag.Title = "Delete";
}

<div class="row">
    <div class="col">
        <h2 class="display-4 alert alert-danger">Are you sure to delete this customer?</h2>
        @using (Html.BeginForm("Delete", "Customers", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            <div class="row">
                <div class="col-6">

                    @Html.HiddenFor(x => x.CustomersId)
                    @Html.HiddenFor(x => x.Picture)

                    <div class="row mb-2">
                        @Html.LabelFor(x => x.CustomersName, htmlAttributes: new { @class = "col-form-label col-form-label-sm col-2" })
                        <div class="col-8">
                            @Html.TextBoxFor(x => x.CustomersName, new { @class = "form-control form-control-sm" })
                        </div>
                        <div class="col-2">
                            @Html.ValidationMessageFor(x => x.CustomersName, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-2">
                        @Html.LabelFor(x => x.PaymentDate, htmlAttributes: new { @class = "col-form-label col-form-label-sm col-2" })
                        <div class="col-8">
                            @Html.TextBoxFor(x => x.PaymentDate, "{0:yyyy-MM-dd}", new { @class = "form-control form-control-sm", type = "date" })
                        </div>
                        <div class="col-2">
                            @Html.ValidationMessageFor(x => x.PaymentDate, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-2">
                        @Html.LabelFor(x => x.CustomerSize, htmlAttributes: new { @class = "col-form-label col-form-label-sm col-2" })
                        <div class="col-8">
                            @Html.TextBoxFor(x => x.CustomerSize, new { @class = "form-control form-control-sm" })
                        </div>
                        <div class="col-2">
                            @Html.ValidationMessageFor(x => x.CustomerSize, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-2">
                        @Html.LabelFor(x => x.PictureFile, htmlAttributes: new { @class = "col-form-label col-form-label-sm col-2" })
                        <div class="col-8">
                            @Html.TextBoxFor(x => x.PictureFile, new { @class = "form-control form-control-sm", type = "file" })
                            <img src="@Model.Picture" width="32" height="32" style="border-radius:5px;" />
                        </div>
                        <div class="col-2">
                            @Html.ValidationMessageFor(x => x.PictureFile, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-2">
                        @Html.LabelFor(x => x.UrgentDelivery, htmlAttributes: new { @class = "col-form-label col-form-label-sm col-2" })
                        <div class="col-8">
                            @Html.CheckBoxFor(x => x.UrgentDelivery)
                        </div>
                        <div class="col-2">
                            @Html.ValidationMessageFor(x => x.UrgentDelivery, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-10 offset-2">
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </div>
                    </div>
                </div>

                <div class="col-6">
                    <h2 class="display-4">Product List</h2>
                    <div class="d-flex justify-content-end">
                        <a class="btn btn-primary btn-sm mb-2" href="#" id="btnPlus"><i class="fa fa-plus"></i></a>
                    </div>
                    <div id="productContainer">
                        @foreach (var item in Model.ProductList)
                        {
                            @Html.Action("AddNewProduct", "Customers", new { id = item })
                        }
                    </div>
                </div>
            </div>
            <div class="row mt-2">
                <div id="msg"></div>
            </div>
        }
    </div>
</div>