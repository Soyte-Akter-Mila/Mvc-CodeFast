@model IEnumerable<Mila_Fashion.Models.Customer>
@{
    ViewBag.Title = "Index";
}

<div class="row">
    <div class="col">
        <h2 class="display-4">Customer List</h2>
        <div class="d-flex justify-content-end">
            <a class="btn btn-primary btn-sm mb-2" href="@Url.Action("Create","Customers")">Add New Customer</a>
        </div>
        <div>
            @foreach (var cust in Model)
            {
                <div class="card mb-2">
                    <div class="card-header d-flex justify-content-between">
                        <div>
                            <img src="@cust.Picture" width="42" height="42" style="border-radius:5px;" />
                            <label class="me-2"><b>Customer :</b> @Html.DisplayFor(x => cust.CustomersName)</label>
                            <label class="me-2"><b>Payment Date :</b> @Html.DisplayFor(x => cust.PaymentDate)</label>
                            <label class="me-2"><b>Size :</b> @Html.DisplayFor(x => cust.CustomerSize)</label>
                            <label class="me-2"><b>Urgent Delivery :</b> @Html.DisplayFor(x => cust.UrgentDelivery)</label>
                        </div>
                        <div class="d-flex justify-content-end">
                            <a class="btn btn-success btn-sm me-1" href="@Url.Action("Edit", "Customers", new {id=cust.CustomersId})">Edit</a>
                            <a class="btn btn-danger btn-sm" href="@Url.Action("Delete", "Customers", new {id=cust.CustomersId})">Delete</a>
                        </div>
                    </div>
                    <div class="card-body">
                        <table class="table table-bordered table-striped table-sm">
                            <thead class="table-info">
                                <tr>
                                    <th>Product Id</th>
                                    <th>Product Name</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in cust.OrderEntries)
                                {
                                    <tr>
                                        <td>@Html.DisplayFor(x => item.Product.ProductsId)</td>
                                        <td>@Html.DisplayFor(x => item.Product.ProductsName)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</div>